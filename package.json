{
  "name": "ro-agent-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "uv run uvicorn api.main:app --reload --port 8000",
    "dev:stack": "docker compose up -d",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "gen:types": "openapi-typescript http://localhost:8000/openapi.json -o packages/types/src/api.ts",
    "test:api": "uv run pytest",
    "test:evals": "uv run pytest tests/evals -v"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
